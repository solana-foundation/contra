{
  "uid": "contra-health",
  "title": "Contra Health Overview",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["contra", "pipeline", "blackbox"],
  "panels": [
    {
      "id": 4,
      "type": "timeseries",
      "title": "Indexer lag (chain_tip − current_slot)",
      "description": "How far behind chain tip the indexer is, per program_type. Sanity threshold: ≤ 50.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "contra_indexer_chain_tip_slot - contra_indexer_current_slot",
          "legendFormat": "{{program_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Operator backlog depth",
      "description": "Pending transactions per operator program_type. Sanity threshold: ≤ 100.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "contra_operator_backlog_depth",
          "legendFormat": "{{program_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Feepayer balance (SOL)",
      "description": "contra_feepayer_balance_lamports / 1e9 per program_type. Sanity threshold: ≥ 0.1 SOL (1e8 lamports).",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "contra_feepayer_balance_lamports / 1e9",
          "legendFormat": "{{program_type}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "green", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Yellowstone gRPC reconnects (rate / 1m)",
      "description": "rate(contra_indexer_datasource_reconnects_total[1m]). Sustained non-zero indicates upstream gRPC instability.",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(contra_indexer_datasource_reconnects_total[1m])",
          "legendFormat": "{{program_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Dedup throughput (rate / 10s)",
      "description": "rate(contra_dedup_received_total[10s]) on write-node. Requires CONTRA_METRICS=true on contra-app services — panel shows 'No data' until enabled.",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(contra_dedup_received_total[10s])",
          "legendFormat": "received/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Gateway error ratio",
      "description": "sum(contra_gateway_errors_total) / sum(contra_gateway_requests_total). Sanity threshold: < 0.05. Requires CONTRA_METRICS=true on the gateway.",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(contra_gateway_errors_total) / clamp_min(sum(contra_gateway_requests_total), 1)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Service Up (blackbox probe_success)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_success",
          "legendFormat": "{{instance}}",
          "instant": false,
          "range": true
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP probe duration (s)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_duration_seconds",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Last failure (seconds since last probe_success=1)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max by (instance) (timestamp(probe_success == 1))",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
