# Contra Load Test Configuration

# Write endpoint for sending transactions
VITE_WRITE_URL=https://write.onlyoncontra.xyz

# Read endpoint for fetching transaction status
VITE_READ_URL=https://read.onlyoncontra.xyz

# Admin keypair as JSON array of bytes (64 bytes: 32 secret + 32 public)
# Leave empty if you don't have admin access
VITE_ADMIN_KEYPAIR=