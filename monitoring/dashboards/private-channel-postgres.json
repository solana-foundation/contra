{
  "uid": "private-channel-postgres",
  "title": "Postgres",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["postgres"],
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Up",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "pg_up", "legendFormat": "{{db}}" }],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      }
    },
    {
      "id": 2, "type": "timeseries", "title": "Active connections",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum by (db) (pg_stat_activity_count)", "legendFormat": "{{db}}" }]
    },
    {
      "id": 3, "type": "timeseries", "title": "Transactions / sec",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (db, datname) (rate(pg_stat_database_xact_commit[1m]))", "legendFormat": "{{datname}} commit" },
        { "refId": "B", "expr": "sum by (db, datname) (rate(pg_stat_database_xact_rollback[1m]))", "legendFormat": "{{datname}} rollback" }
      ]
    },
    {
      "id": 4, "type": "timeseries", "title": "Replication lag (s)",
      "description": "pg_replication_lag_seconds. Sustained > 30s = replica falling behind primary. Only meaningful on the primary instance; the replica reports 0 (it has nothing replicating off it).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "pg_replication_lag_seconds", "legendFormat": "{{db}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "id": 5, "type": "stat", "title": "Cache hit ratio",
      "description": "blks_hit / (blks_hit + blks_read), summed across DBs per instance. < 0.99 = working set outgrew shared_buffers (per the README guidance).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (db) (pg_stat_database_blks_hit) / clamp_min(sum by (db) (pg_stat_database_blks_hit + pg_stat_database_blks_read), 1)", "legendFormat": "{{db}}", "instant": true }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      }
    },
    {
      "id": 6, "type": "timeseries", "title": "Longest in-flight transaction (s)",
      "description": "pg_stat_activity_max_tx_duration. The exporter reports max(now() − xact_start) per backend state. Sustained large values flag stuck/blocking transactions; pg_stat_statements would give per-statement timing but isn't enabled here.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "max by (db, state) (pg_stat_activity_max_tx_duration)", "legendFormat": "{{db}} / {{state}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      }
    }
  ]
}
